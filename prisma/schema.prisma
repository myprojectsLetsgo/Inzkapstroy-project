generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Lead {
  id          Int      @id @default(autoincrement())
  name        String
  phone       String
  email       String?
  description String?
  status      String   @default("new")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  ip          String?
}

model Admin {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  password  String
  role      String   @default("admin")
  createdAt DateTime @default(now())
}

model Log {
  id        Int      @id @default(autoincrement())
  action    String
  userId    Int?
  details   String?
  createdAt DateTime @default(now())
}
